<style>
  .thank-you-banner {
    background-color: #fff9c2;
    width: 100%;
    padding: 0.6rem;
    text-align: center;
    border-bottom: 1px solid #fff785;
  }

  .thank-you-banner p {
    margin: 0;
    font-size: 1rem;
    line-height: 1.4;
    max-width: 800px;
    margin: 0 auto;
  }

  .highlight {
    background-color: #fffa02;
    padding: 0.1rem 0.3rem;
    border-radius: 3px;
    font-weight: 500;
  }

  @media (max-width: 640px) {
    .thank-you-banner p {
      font-size: 0.9rem;
      padding: 0 1rem;
    }
  }
</style>

---
import Layout from "../layouts/Layout.astro";
import Stats from "../components/Stats.astro";
import Image from "../components/Image.astro";
import Timeline from "../components/Timeline.astro";
import Wanted from "../components/Wanted.astro";
import Accordion from "../components/Accordion.astro";
import OpenAgendaIntegration from "../components/OpenAgendaIntegration.astro";
import Navbar from "../components/Navbar.astro";
import ThankYouBanner from "../components/ThankYouBanner.astro";
import DonationBanner from "../components/DonationBanner.astro";

import "../styles/global.css";
---

<Layout title="L'Agenda des Voisins">
  <ThankYouBanner />
    <!-- <DonationBanner /> -->
  <Navbar />

  <section>
    <h1>L'Agenda des Voisins</h1>

    <p>
      L'Agenda des Voisins est un agenda de voisinage participatif qui rend visibles les événements locaux afin de favoriser les rencontres, créer du lien et permet à chacun de découvrir et participer à la vie locale quel que soit son degré de connexion au monde numérique
    </p>

    <Image
      src="~/assets/images/DoodledBird.png"
      alt="logo"
      class="logo"
      width={100}
      height={100}
      layout="contained"
    />
    <Stats
      stats={[
        { title: "Agendas distribués", amount: "1300" },
        { title: "Villages touchés", amount: "19" },
        { title: "Contributeurs", amount: "33" },
      ]}
    />
  </section>
  <section>
    <h2>Contribuer à l'agenda !</h2>
    <button type="button">
      <a href="/contribuer#ajouter-evenement">
        🠖 Ajoutez un événement 🠔
      </a>
    </button>
    <button type="button">
      <a href="/contribuer#devenir-contributeur">
        🠖 Devenez contributeur 🠔
      </a>
    </button>
  </section>
  <section>
    <h2>Abonnez-vous à l'Agenda des Voisins par email</h2>
    <p>
      Recevez chaque mois, l'Agenda des Voisins dans votre boite mail en vous
      abonnant
    </p>
    <button class="" type="button"
      ><a
        href="https://2d0490c4.sibforms.com/serve/MUIFAKxnQ49tMFt7TjG78nDsMoV8mOkciJKi52QlM7yLb48XDCA2Xaebq_B5M1s7yjaNTHeos7ao08ikUOZ8keIr9FjZn7_nZBkyITAlpoPq6vd5LyNzYKnjj2mtgu7QzcoXFGE779_3wvPjh2vNFmSVIuNzUAT70g7Iu2Dqkxve7a895fIWyCqmcONYeJls0uWcYdoS6Cys3w7u"
        target="_blank">🠖 S'abonner à l'Agenda des Voisins par email 🠔</a
      ></button>
      <h2>Consulter les évenements de l'Agenda</h2>
      <OpenAgendaIntegration/>
  </section>
